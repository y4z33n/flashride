# FlashRide Server — Environment Variables
# Copy this file to .env and fill in all values before running locally.
# NEVER commit .env to git.

# ── Supabase ──────────────────────────────────────────────
# Get these from: https://app.supabase.com → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Server ────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Dev:  Expo Go + local web dev server
# Prod: set to your deployed Vercel frontend URL
CORS_ORIGINS=http://localhost:8081,http://localhost:3000,http://localhost:19006

# ── Admin ─────────────────────────────────────────────────
# Static secret for /admin/* endpoints.
# Generate with: openssl rand -hex 32
# Must be set in production — admin routes are blocked if empty.
ADMIN_SECRET=change-me-use-openssl-rand-hex-32



# ── App version ───────────────────────────────────────────
# Bumped on each release. Used by GET /version.
APP_VERSION=1.0.0
