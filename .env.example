# ── Supabase ─────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/_/settings/api
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# ── Backend API ───────────────────────────────────────────────
# Local dev:  http://localhost:3001
# Production: https://flashride.onrender.com
EXPO_PUBLIC_API_URL=http://localhost:3001

# ── Google Maps ───────────────────────────────────────────────
# Create a key at: https://console.cloud.google.com/apis/credentials
# Restrict it to: Maps SDK for Android, Maps SDK for iOS, Maps JavaScript API
# Restrict by: Android package (com.flashride.app) + SHA-1, iOS bundle ID
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
